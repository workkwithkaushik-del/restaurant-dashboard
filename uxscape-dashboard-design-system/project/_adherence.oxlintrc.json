{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "components/navigation/**",
              "restaurant_dashboard_ui_kit/**",
              "restaurant_dashboard_ui_kit/parts/**",
              "restaurant_dashboard_ui_kit/screens/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Cormorant Garamond|Hanken Grotesk))/i]",
        "message": "Font not provided by the design system. Available: Cormorant Garamond, Hanken Grotesk."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|size|variant|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: initials, size, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:user|brand|soft)$/]",
        "message": "<Avatar> variant must be one of 'user' | 'brand' | 'soft'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warning|danger|info|neutral)$/]",
        "message": "<Badge> tone must be one of 'success' | 'warning' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='BrandMark'] > JSXAttribute > JSXIdentifier[name!=/^(?:initials|size|key|ref|className|style|children)$/]",
        "message": "<BrandMark> doesn't accept that prop. Declared props: initials, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|link|mini)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'link' | 'mini'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CommandInput'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|key|ref|className|style|children)$/]",
        "message": "<CommandInput> doesn't accept that prop. Declared props: label, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeedbackCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:user|rating|badge|content|time|style|key|ref|className|style|children)$/]",
        "message": "<FeedbackCard> doesn't accept that prop. Declared props: user, rating, badge, content, time, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FieldSelect'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|onChange|children|size|key|ref|className|style|children)$/]",
        "message": "<FieldSelect> doesn't accept that prop. Declared props: label, value, onChange, children, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='FieldSelect'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<FieldSelect> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Hero'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|children|status|style|key|ref|className|style|children)$/]",
        "message": "<Hero> doesn't accept that prop. Declared props: eyebrow, title, children, status, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|size|children|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: tone, size, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|dark)$/]",
        "message": "<IconButton> tone must be one of 'default' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<IconButton> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|change|accent|key|ref|className|style|children)$/]",
        "message": "<MetricCard> doesn't accept that prop. Declared props: label, value, change, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='MetricCard'] > JSXAttribute[name.name='accent'] > Literal[value!=/^(?:green|blue|amber|coral|purple)$/]",
        "message": "<MetricCard> accent must be one of 'green' | 'blue' | 'amber' | 'coral' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='MiniMeter'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|suffix|key|ref|className|style|children)$/]",
        "message": "<MiniMeter> doesn't accept that prop. Declared props: value, label, suffix."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|children|ctaText|onCta|cancelText|width|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, onClose, title, children, ctaText, onCta, cancelText, width."
      },
      {
        "selector": "JSXOpeningElement[name.name='Panel'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|action|padding|children|key|ref|className|style|children)$/]",
        "message": "<Panel> doesn't accept that prop. Declared props: eyebrow, title, action, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='RangeSwitch'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|ariaLabel|style|key|ref|className|style|children)$/]",
        "message": "<RangeSwitch> doesn't accept that prop. Declared props: options, value, onChange, ariaLabel, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Sidebar'] > JSXAttribute > JSXIdentifier[name!=/^(?:collapsed|children|style|key|ref|className|style|children)$/]",
        "message": "<Sidebar> doesn't accept that prop. Declared props: collapsed, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SidebarItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|children|active|collapsed|title|onClick|style|key|ref|className|style|children)$/]",
        "message": "<SidebarItem> doesn't accept that prop. Declared props: icon, children, active, collapsed, title, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|warning|danger|info|neutral)$/]",
        "message": "<StatusPill> tone must be one of 'success' | 'warning' | 'danger' | 'info' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SummaryCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|detail|tone|children|key|ref|className|style|children)$/]",
        "message": "<SummaryCard> doesn't accept that prop. Declared props: label, value, detail, tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SummaryCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:green|blue|amber|purple)$/]",
        "message": "<SummaryCard> tone must be one of 'green' | 'blue' | 'amber' | 'purple'."
      },
      {
        "selector": "JSXOpeningElement[name.name='UsageGuideBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|icon|title|children|steps|onDismiss|style|key|ref|className|style|children)$/]",
        "message": "<UsageGuideBanner> doesn't accept that prop. Declared props: tone, icon, title, children, steps, onDismiss, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='UsageGuideBanner'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:warning|success)$/]",
        "message": "<UsageGuideBanner> tone must be one of 'warning' | 'success'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ViewTabs'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<ViewTabs> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='WarningBanner'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|children|style|key|ref|className|style|children)$/]",
        "message": "<WarningBanner> doesn't accept that prop. Declared props: icon, children, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
